<html>
<head>
    <title>Tourist Reservation Form</title>
</head>

<body bgcolor="#E6F7FF">

<center>

<h1>TOURIST RESERVATION FORM</h1>
<p>Please complete the form below to reserve your tour.</p>

<form>

<table border="0" cellpadding="20"  cellspacing="0"><br><br>

<tr>
    <td>Full Name:</td>
    <td><input type="text" name="fullname" size="30" required></td>
</tr>

<tr>
    <td>Age:</td>
    <td><input type="number" name="age" min="1" max="100"></td>
</tr>

<tr>
    <td>Gender:</td>
    <td>
        <input type="radio" name="gender"> Male
        <input type="radio" name="gender"> Female
    </td>
</tr>

<tr>
    <td>Email Address:</td>
    <td><input type="email" name="email" size="30"></td>
</tr>

<tr>
    <td>Phone Number:</td>
    <td><input type="tel" name="phone" size="30"></td>
</tr>

<tr>
    <td>Tour Destination:</td>
    <td>
        <select>
            <option>LUZON</option>
            <option>Apayo</option>
            <option>Benguet</option>
            <option>Ifugao</option>
            <option></option>
        </select>
    </td>
</tr>

<tr>
    <td>Visit Date:</td>
    <td><input type="date"></td>
</tr>

<tr>
    <td>Number of Visitors:</td>
    <td><input type="number" min="1" max="20"></td>
</tr>

<tr>
    <td>Special Requests:</td>
    <td>
        <textarea rows="4" cols="30"></textarea>
    </td>
</tr>

<tr>
    <td colspan="2" align="center">

       <a href="confirmation.html">
    <button type="button">Reserve Now</button></a>

<a href="confirmation.html">
    <button type="button">Cancel</button>
</a>
    </td>
</tr>

</table>

</form>

</center>

</body>
</html>